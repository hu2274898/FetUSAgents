# Example environment file. Copy to `.env` and source before running.
#
#   cp configs/env.example .env
#   set -a; . ./.env; set +a
#
# All variables are also honoured when set via your shell rc or systemd unit.

# --- LLM ---------------------------------------------------------------------
export OPENAI_API_KEY=""
export OPENAI_MODEL="gpt-5.1"
export OPENAI_BASE_URL="https://api.openai.com/v1"

# --- Project locations (used for sys.path import only — never modified) ------
export FETUSAGENTS_CONFIG="configs/paths.local.yaml"

# --- Conda env Python paths (forwarded to the CV tool wrappers) -------------
export FETALAGENT_HXT_BASE_PYTHON="/path/to/envs/hxt_base/bin/python"
export FETALAGENT_FETALCLIP_PYTHON="/path/to/envs/fetalclip/bin/python"
export FETALAGENT_FETALCLIP2_PYTHON="/path/to/envs/fetalclip2/bin/python"
export FETALAGENT_EXPERIMENT_AAAI_PYTHON="/path/to/envs/experiment_aaai/bin/python"
export FETALAGENT_USFM_PYTHON="/path/to/envs/USFM/bin/python"
export FETALAGENT_NNUNET_PREDICT="/path/to/envs/hxt_base/bin/nnUNetv2_predict"

# --- Checkpoint root ---------------------------------------------------------
export FETALAGENT_CKPT_DIR="/path/to/FetalAgent_ckpt"

# --- Batch VQA dataset roots (only needed for `fetalagent --task_name ...`) --
# Both default to ./Agent_VQA and ./datasets respectively if unset.
# CLI args --vqa_json / --image_dir still override per-call.
export FETUSAGENTS_VQA_DIR="/path/to/Agent_VQA"
export FETUSAGENTS_DATA_DIR="/path/to/datasets"

# --- Logging / debugging knobs forwarded to the CV tools ---------------------
export AGENT_PRINT_TOOL_OUTPUT="0"
export AGENT_PRINT_TOOL_CMD="0"
